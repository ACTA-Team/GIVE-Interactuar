# =============================================================================
# GIVE Interactuar — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# =============================================================================

# =============================================================================
# Supabase
# Get these from: https://supabase.com/dashboard → Project → Settings → API
# For local dev run `supabase start` and copy from the printed output.
# =============================================================================

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# WARNING: service role key bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# App
# =============================================================================

# Base URL used for building absolute links (e.g. verification portal share URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Stellar
# =============================================================================

# Active network: testnet | mainnet | futurenet
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# =============================================================================
# Google Forms sync
# Service account credentials for Google Forms API v1.
# Docs: https://developers.google.com/forms/api/reference/rest
# Steps:
#   1. Create a Google Cloud project
#   2. Enable the Google Forms API
#   3. Create a Service Account and download the JSON key
#   4. Share each Google Form with the service account email (viewer role)
# =============================================================================

# The Google Cloud service account email (e.g. my-sa@project.iam.gserviceaccount.com)
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# The private key from the service account JSON (include \n line breaks as-is)
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# The Google Form ID from the form URL:
# https://docs.google.com/forms/d/<FORM_ID>/edit
GOOGLE_FORM_ID=your-google-form-id

# The UUID of the form_sources row in Supabase that corresponds to GOOGLE_FORM_ID
# Created via seed.sql or manually in the dashboard.
GOOGLE_FORM_SOURCE_ID=00000000-0000-0000-0000-000000000000

# =============================================================================
# Cron security
# Used to verify that /api/cron/forms-sync is called by an authorized scheduler.
# Generate with: openssl rand -hex 32
# Set the same value in Vercel → Project → Settings → Cron Jobs (Authorization header).
# =============================================================================

CRON_SECRET=replace-with-a-random-secret
