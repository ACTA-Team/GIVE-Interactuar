{
  "$id": "https://acta.do/schemas/mba-program-credential.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MBA Program Credential",
  "description": "W3C VC 2.0 schema for participation and completion of the MBA Empresarial program.",
  "type": "object",
  "required": ["@context", "type", "issuer", "validFrom", "credentialSubject"],
  "properties": {
    "@context": {
      "type": "array",
      "contains": {
        "const": "https://www.w3.org/ns/credentials/v2"
      }
    },
    "id": {
      "type": "string",
      "format": "uri"
    },
    "type": {
      "type": "array",
      "allOf": [
        {
          "contains": {
            "const": "VerifiableCredential"
          }
        },
        {
          "contains": {
            "const": "MBAProgramCredential"
          }
        }
      ]
    },
    "issuer": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "credentialSubject": {
      "type": "object",
      "required": [
        "id",
        "holderName",
        "company",
        "programName",
        "cohortYear",
        "partnerName",
        "programLevel",
        "programGroup"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Identifier of the subject, e.g. urn:give:entrepreneur:<uuid> or a DID."
        },
        "holderName": {
          "type": "string",
          "description": "Full name of the MBA participant (from empresarios.name)."
        },
        "company": {
          "type": ["string", "null"],
          "description": "Company name (from empresarios.company)."
        },
        "programName": {
          "type": "string",
          "description": "Program name, e.g. 'MBA Empresarial'."
        },
        "cohortYear": {
          "type": "integer",
          "description": "Cohort year, from empresarios.cohort_year (e.g. 2024)."
        },
        "cohortLabel": {
          "type": "string",
          "description": "Human-readable label, e.g. 'Cohorte 2024'."
        },
        "partnerName": {
          "type": "string",
          "description": "Main partner, e.g. 'Alianza Comfama' (from empresarios.partner)."
        },
        "programLevel": {
          "type": "string",
          "description": "Program level, mapped from empresarios.level, e.g. 'Nivel 2'."
        },
        "programGroup": {
          "type": "string",
          "description": "Program group, from empresarios.\"group\", e.g. 'G7 Centro'."
        },
        "programDisplayTitle": {
          "type": "string",
          "description": "Combined text for UI, e.g. 'MBA Empresarial · Cohorte 2024'."
        },
        "programDisplaySubtitle": {
          "type": "string",
          "description": "Combined text for UI, e.g. 'Aliado: Alianza Comfama · Nivel 2 · G7 Centro'."
        },
        "datasetProgram": {
          "type": ["string", "null"],
          "description": "Raw value from empresarios.program."
        },
        "datasetPartner": {
          "type": ["string", "null"],
          "description": "Raw value from empresarios.partner."
        },
        "datasetStatus": {
          "type": ["string", "null"],
          "description": "Program status from empresarios.status."
        },
        "datasetMunicipality": {
          "type": ["string", "null"],
          "description": "Municipality from empresarios.municipality."
        },
        "datasetSector": {
          "type": ["string", "null"],
          "description": "Sector from empresarios.sector."
        },
        "datasetSalesPrevYearCop": {
          "type": ["number", "null"],
          "description": "Previous year sales in COP from empresarios.sales_prev_year_cop."
        },
        "datasetSalesCop": {
          "type": ["number", "null"],
          "description": "Current sales in COP from empresarios.sales_cop."
        },
        "datasetGrowthPct": {
          "type": ["number", "null"],
          "description": "Growth percentage from empresarios.growth_pct."
        },
        "datasetNewJobs": {
          "type": ["integer", "null"],
          "description": "New jobs from empresarios.new_jobs."
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

