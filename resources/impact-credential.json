{
  "$id": "https://acta.do/schemas/impact-credential.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Impact Credential",
  "description": "W3C VC 2.0 schema for business impact and growth assessment.",
  "type": "object",
  "required": ["@context", "type", "issuer", "validFrom", "credentialSubject"],
  "properties": {
    "@context": {
      "type": "array",
      "contains": {
        "const": "https://www.w3.org/ns/credentials/v2"
      }
    },
    "id": {
      "type": "string",
      "format": "uri"
    },
    "type": {
      "type": "array",
      "allOf": [
        {
          "contains": {
            "const": "VerifiableCredential"
          }
        },
        {
          "contains": {
            "const": "ImpactCredential"
          }
        }
      ]
    },
    "issuer": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "credentialSubject": {
      "type": "object",
      "required": [
        "id",
        "companyName",
        "sector",
        "yearsInOperation",
        "salesPreviousYear",
        "salesCurrentYear",
        "salesVariationPercent",
        "currentEmployees",
        "newJobsCreated",
        "newFormalJobsCreated",
        "businessTrend"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "companyName": {
          "type": "string",
          "minLength": 1
        },
        "sector": {
          "type": "string",
          "minLength": 1
        },
        "yearsInOperation": {
          "type": "number",
          "minimum": 0
        },
        "salesPreviousYear": {
          "type": "number",
          "minimum": 0
        },
        "salesCurrentYear": {
          "type": "number",
          "minimum": 0
        },
        "salesVariationPercent": {
          "type": "number"
        },
        "currentEmployees": {
          "type": "integer",
          "minimum": 0
        },
        "newJobsCreated": {
          "type": "integer",
          "minimum": 0
        },
        "newFormalJobsCreated": {
          "type": "integer",
          "minimum": 0
        },
        "businessTrend": {
          "type": "string",
          "enum": ["growing", "stable", "deteriorating"]
        },
        "assessmentPeriod": {
          "type": "object",
          "properties": {
            "startDate": {
              "type": "string",
              "format": "date"
            },
            "endDate": {
              "type": "string",
              "format": "date"
            }
          },
          "required": ["startDate", "endDate"],
          "additionalProperties": false
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "source": {
                "type": "string"
              },
              "hash": {
                "type": "string"
              }
            },
            "required": ["type"],
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}