{
  "$id": "https://acta.do/schemas/behavior-credential.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Behavior Credential",
  "description": "W3C VC 2.0 schema for financial behavior, repayment capacity, and business stability signals.",
  "type": "object",
  "required": ["@context", "type", "issuer", "validFrom", "credentialSubject"],
  "properties": {
    "@context": {
      "type": "array",
      "contains": {
        "const": "https://www.w3.org/ns/credentials/v2"
      }
    },
    "id": {
      "type": "string",
      "format": "uri"
    },
    "type": {
      "type": "array",
      "allOf": [
        {
          "contains": {
            "const": "VerifiableCredential"
          }
        },
        {
          "contains": {
            "const": "BehaviorCredential"
          }
        }
      ]
    },
    "issuer": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": {
              "type": "string"
            },
            "name": {
              "type": "string"
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "validFrom": {
      "type": "string",
      "format": "date-time"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "credentialSubject": {
      "type": "object",
      "required": [
        "id",
        "creditSegmentStart",
        "creditSegmentEnd",
        "averageSales",
        "costsAndExpenses",
        "assets",
        "liabilities",
        "estimatedOperatingMargin",
        "liabilitiesToAssetsRatio",
        "monthlyIncomeStability",
        "registryValidation",
        "newJobs",
        "estimatedOperationalCapacity",
        "leverageLevel",
        "commercialStability",
        "financialTrend",
        "paymentCapacitySignal"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "creditSegmentStart": {
          "type": "string"
        },
        "creditSegmentEnd": {
          "type": "string"
        },
        "activeCredit": {
          "type": ["object", "null"],
          "properties": {
            "exists": {
              "type": "boolean"
            },
            "amount": {
              "type": "number",
              "minimum": 0
            },
            "currency": {
              "type": "string"
            },
            "status": {
              "type": "string",
              "enum": ["current", "late", "restructured", "closed"]
            }
          },
          "required": ["exists"],
          "additionalProperties": false
        },
        "averageSales": {
          "type": "number",
          "minimum": 0
        },
        "costsAndExpenses": {
          "type": "number",
          "minimum": 0
        },
        "assets": {
          "type": "number",
          "minimum": 0
        },
        "liabilities": {
          "type": "number",
          "minimum": 0
        },
        "estimatedOperatingMargin": {
          "type": "number"
        },
        "liabilitiesToAssetsRatio": {
          "type": "number",
          "minimum": 0
        },
        "monthlyIncomeStability": {
          "type": "string",
          "enum": ["high", "medium", "low", "volatile"]
        },
        "registryValidation": {
          "type": "string",
          "enum": ["validated", "partially_validated", "not_validated"]
        },
        "newJobs": {
          "type": "integer",
          "minimum": 0
        },

        "estimatedOperationalCapacity": {
          "type": "string",
          "enum": ["strong", "moderate", "weak"]
        },
        "leverageLevel": {
          "type": "string",
          "enum": ["low", "moderate", "high"]
        },
        "commercialStability": {
          "type": "string",
          "enum": ["stable", "seasonal", "volatile"]
        },
        "financialTrend": {
          "type": "string",
          "enum": ["improving", "stable", "deteriorating"]
        },
        "paymentCapacitySignal": {
          "type": "string",
          "enum": ["strong", "acceptable", "weak", "critical"]
        },

        "assessmentMethod": {
          "type": "object",
          "properties": {
            "version": {
              "type": "string"
            },
            "derivedIndicatorsIncluded": {
              "type": "boolean"
            },
            "notes": {
              "type": "string"
            }
          },
          "required": ["version", "derivedIndicatorsIncluded"],
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}