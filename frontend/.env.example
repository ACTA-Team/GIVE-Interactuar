# The Google Form ID from the form URL:
# https://docs.google.com/forms/d/<FORM_ID>/edit
GOOGLE_FORM_ID=your-google-form-id

# The UUID of the form_sources row in Supabase that corresponds to GOOGLE_FORM_ID
# Created via seed.sql or manually in the dashboard.
GOOGLE_FORM_SOURCE_ID=00000000-0000-0000-0000-000000000000

# =============================================================================
# Cron security
# Used to verify that /api/cron/forms-sync is called by an authorized scheduler.
# Generate with: openssl rand -hex 32
# Set the same value in Vercel → Project → Settings → Cron Jobs (Authorization header).
# =============================================================================

CRON_SECRET=replace-with-a-random-secret
